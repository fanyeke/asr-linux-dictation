# ASR Linux — Environment Variables
# Copy this to .env and fill in your API keys.
# All keys can also be configured via the Settings UI at runtime.

# --- API Keys (set via Settings UI instead if preferred) ---
# ASR service (MiMo)
# ASR_LINUX_MIMO_API_KEY=
# LLM service (OpenAI-compatible)
# ASR_LINUX_LLM_API_KEY=
# Also accepted as fallback for LLM key:
# OPENAI_API_KEY=

# --- API Authentication ---
# If set, backend requires X-Token header matching this value.
# ASR_LINUX_SECRET_TOKEN=

# --- Audio ---
# ASR_LINUX_AUDIO_SAMPLE_RATE=16000
# ASR_LINUX_AUDIO_CHANNELS=1
# ASR_LINUX_AUDIO_DEVICE=
# ASR_LINUX_SILENCE_THRESHOLD=0.005
# ASR_LINUX_SILENCE_DURATION_MS=2000

# --- Misc ---
# ASR_LINUX_LOG_LEVEL=info
# ASR_LINUX_HOST=127.0.0.1
# ASR_LINUX_DATA_DIR=
