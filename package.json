{
  "name": "asr-linux-electron",
  "version": "0.2.0",
  "description": "ASR Linux Electron frontend",
  "type": "module",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "tsc && npm run build:renderer && cp -r assets dist/",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepack": "pip3 install --quiet --target python-deps fastapi uvicorn httpx pydantic pydantic-settings structlog pypinyin || true",
    "pack": "npm run build && npm run prepack && electron-builder --linux",
    "pack:dir": "npm run build && npm run prepack && electron-builder --linux --dir"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "clsx": "^2.1.1",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "main": "dist/electron/main/main.js",
  "build": {
    "appId": "com.asrlinux.app",
    "productName": "ASR Linux",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/ws/**/*"
    ],
    "extraResources": [
      {
        "from": "src/backend",
        "to": "backend"
      },
      {
        "from": "python-deps",
        "to": "python-deps"
      },
      {
        "from": "pyproject.toml",
        "to": "pyproject.toml"
      },
      {
        "from": "uv.lock",
        "to": "uv.lock"
      },
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "tar.gz",
          "arch": ["x64"]
        }
      ],
      "category": "AudioVideo",
      "icon": "assets/icon.png"
    }
  }
}
